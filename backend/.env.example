# VyaparSETU Backend Environment Configuration
# Copy this file to .env inside the backend/ directory and add your actual API keys

# 1. Google Gemini API Key (Required for LLM Intent Parsing and Qdrant Embeddings)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 2. Qdrant Vector Database Configuration
QDRANT_HOST=localhost

# 3. Meta Cloud / Twilio (Optional for live WhatsApp automation)
META_CLOUD_API_TOKEN=
META_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
HACKATHON_TEST_PHONE=918591852051
